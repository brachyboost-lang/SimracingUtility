@{
    ViewData["Title"] = "LMU-Agent herunterladen";
    var agentAvailable = ViewBag.AgentAvailable as bool? ?? false;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">LMU-Agent</h1>
    @if (agentAvailable)
    {
        <a asp-action="Agent" class="btn btn-primary">Agent herunterladen (.zip)</a>
    }
    else
    {
        <button class="btn btn-secondary" disabled>Aktuell nicht verfügbar</button>
    }
</div>

@if (TempData["DownloadMessage"] != null)
{
    <div class="alert alert-warning">@TempData["DownloadMessage"]</div>
}

<p class="lead">
    Der LMU-Agent ist ein lokaler Windows-Dienst, der Renndaten direkt aus
    <strong>Le Mans Ultimate</strong> ausliest und für die Team-Webseite bereitstellt.
</p>

<div class="row g-4 mt-1">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Was der Agent macht</h5>
                <ul class="mb-0">
                    <li>Liest die <strong>Rennergebnisse</strong> aus den lokalen
                        LMU-XML-Dateien (Steam-Ordner).</li>
                    <li>Berechnet Fahrer-<strong>Statistiken</strong> (Siege, Podien, beste Runde …)
                        und <strong>pusht</strong> das Dashboard an die Website.</li>
                    <li>Stellt lokal <strong>Telemetrie-Downloads</strong> bereit.</li>
                    <li>Läuft als kleines <strong>Tray-Programm</strong> im Hintergrund und
                        aktualisiert die Daten regelmäßig.</li>
                </ul>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Installation</h5>
                <ol class="mb-0">
                    <li>ZIP herunterladen und entpacken.</li>
                    <li><strong>LMU.Agent.Service.exe</strong> doppelklicken – kein
                        PowerShell, kein Admin, keine separate .NET-Installation nötig.</li>
                    <li>Der Agent läuft im <strong>Infobereich (Tray)</strong>; Beenden
                        über das Tray-Menü. Optional automatischer Start: Verknüpfung in den
                        Autostart-Ordner (<code>Win+R</code> → <code>shell:startup</code>).</li>
                    <li>Bei Bedarf in <code>appsettings.json</code> die
                        <code>Website:BaseUrl</code> (und den Ergebnis-Pfad) anpassen.</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="alert alert-info mt-4 mb-0">
    Voraussetzung: Windows mit installiertem Le&nbsp;Mans&nbsp;Ultimate. Der Agent
    benötigt keine Internetverbindung – er arbeitet rein lokal.
</div>
