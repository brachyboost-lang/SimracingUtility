@model SimracingUtility.Models.FuelCalcViewModel

<style>
    /* Page form container */
    .FuelCalcMain {
        background: linear-gradient(180deg, #0f172a 0%, #0b1220 100%);
        color: #e6eef8;
        padding: 1.25rem;
        border-radius: 8px;
        box-shadow: 0 6px 18px rgba(2,6,23,0.6);
        margin-bottom: 1rem;
    }

    .FuelCalcMain .form-label {
        color: #cfe6ff;
        font-weight: 600;
    }

    .FuelCalcMain .form-control,
    .FuelCalcMain .form-select {
        background: #0b1220;
        color: #e6eef8;
        border: 1px solid #1f334b;
    }

    .FuelCalcMain .form-control:focus,
    .FuelCalcMain .form-select:focus {
        border-color: #2b86ff;
        box-shadow: 0 0 0 0.15rem rgba(43,134,255,0.15);
    }

    .btn-primary {
        background: linear-gradient(90deg,#2b86ff,#1fb6ff);
        border: none;
        box-shadow: 0 6px 14px rgba(43,134,255,0.18);
    }

    /* Table styling */
    table.table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 1rem;
        margin-bottom: 4.5rem; /* space to avoid footer overlap */
        background: linear-gradient(180deg,#071028 0%, #041122 100%);
        color: #ffffff; /* stronger contrast */
        border-radius: 6px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(2,6,23,0.75);
        position: relative;
        z-index: 1;
    }

    /* ensure table headers are clearly visible */
    table.table thead th {
        background: linear-gradient(90deg,#123152 0%,#1b425f 100%);
        color: #fff;
        padding: 0.75rem 1rem;
        text-align: left;
        font-weight: 700;
        border-bottom: 1px solid rgba(255,255,255,0.04);
    }

    table.table tbody td {
        padding: 0.9rem 1rem; /* larger padding for readability */
        border-bottom: 1px solid rgba(255,255,255,0.03);
        color: aqua; /* ensure high contrast */
        background: grey;
    }

    table.table tbody tr:nth-child(even) {
        background: rgba(43,86,128,0.04);
    }

    table.table tbody tr:hover {
        background: rgba(43,134,255,0.04);
    }

    .created-at {
        color: #a9d3ff;
        font-size: 0.95rem;
    }

    media (max-width: 767px) {
        .FuelCalcMain { padding: 0.75rem; }
        table.table thead { display: none; }
        table.table tbody td { display: block; width: 100%; }
    }
</style>

<form id="fuelCalcForm" asp-action="Index" method="post" class="FuelCalcMain">
    @Html.AntiForgeryToken()

    <div class="d-flex flex-column">
        <div class="row">

            <div class="mb-3 col-6">
                <label asp-for="TrackName" class="form-label">Track Name</label>
                <input asp-for="TrackName" class="form-control" />
            </div>

            <div class="mb-3 col-6">
                <label asp-for="EventDurationMinutes" class="form-label">Event Duration (Minutes)</label>
                <input asp-for="EventDurationMinutes" type="number" class="form-control" required />
            </div>
        </div>
        <div class="row">
            <div class="mb-3 col-6">
                <label asp-for="FuelPerLap" class="form-label">Fuel Per Lap</label>
                <input asp-for="FuelPerLap" type="number" step="any" class="form-control" required />
            </div>

            <div class="mb-3 col-6">
                <label asp-for="TimePerLap" class="form-label">Time Per Lap</label>
                <input asp-for="TimePerLap" type="number" step="any" class="form-control" required />
            </div>
        </div>
        <div class="row">
            <div class="mb-3 col-6">
                <label asp-for="CarClass" class="form-label">Car Class</label>
                <select asp-for="CarClass" class="form-select" asp-items="ViewBag.CarClasses">
                    <option value="">-- select class --</option>
                </select>
            </div>
            <div class="mb-3 col-6">
                <label asp-for="CarName" class="form-label">Car Name</label>
                <select asp-for="CarName" class="form-select" asp-items="ViewBag.CarNames">
                    <option value="">-- select car --</option>
                </select>
            </div>
        </div>
        <div class="row">
            <div class="mb-3 col-6">
                <label asp-for="PitBoxTime" class="form-label">Pit Box Time (seconds)</label>
                <input asp-for="PitBoxTime" type="number" step="any" class="form-control" />
            </div>

            <div class="mb-3 col-6">
                <label asp-for="DriveThroughTime" class="form-label">Drive Through Time (seconds)</label>
                <input asp-for="DriveThroughTime" type="number" step="any" class="form-control" />
            </div>
        </div>
        <div class="row">
            <div class="mb-3 col-6">
                <label asp-for="FuelTankCapacity" class="form-label">Fuel Tank Capacity</label>
                <input asp-for="FuelTankCapacity" type="number" step="any" class="form-control" />
            </div>
            <button type="submit" class="btn btn-primary">Calculate</button>
            <div class="container">

                <div class="mb-3">
                    <label asp-for="NumberOfPitStops" class="form-label">Number Of Pit Stops</label>
                    <input asp-for="NumberOfPitStops" type="number" min="0" class="form-control" readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label">Total Laps</label>
                    <input asp-for="Laps" class="form-control" readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label">Total Fuel Needed</label>
                    <input asp-for="TotalFuelNeeded" class="form-control" readonly />
                </div>

            </div>
        </div>
    </div>
</form>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Track Name</th>
            <th>Car Class</th>
            <th>Car Name</th>
            <th>Fuel Per Lap</th>
            <th>Laptime</th>
            <th>Event Duration (Minutes)</th>
            <th>Number of Pitstops</th>
            <th>Number of Laps</th>
            <th>Total Fuel Needed</th>
            <th>Created At</th>

        </tr>
    </thead>
    <tbody>
        @if (ViewBag.RecentFuelCalcs != null && ViewBag.RecentFuelCalcs.Count > 0)
        {
            @foreach (var calc in ViewBag.RecentFuelCalcs)
            {
                <tr>
                    <td>@calc.TrackName</td>
                    <td>@calc.CarClass</td>
                    <td>@calc.CarName</td>
                    <td>@calc.FuelPerLap</td>
                    <td>@calc.TimePerLap</td>
                    <td>@calc.EventDurationMinutes</td>
                    <td>@calc.NumberOfPitStops</td>
                    <td>@calc.Laps</td>
                    <td>@calc.TotalFuelNeeded</td>
                    <td>@(calc.CreatedAt != null ? DateTime.SpecifyKind((DateTime)calc.CreatedAt, DateTimeKind.Utc).ToLocalTime().ToString("g") : "")</td>

                </tr>
            }
        }
    </tbody>
</table>
<script>
    (function () {
        // Read serialized car objects from server via ViewBag
        var carsJson = @Html.Raw(ViewBag.CarsJson ?? "[]");
        var cars = Array.isArray(carsJson) ? carsJson : [];

        var classSelect = document.querySelector('select[name="CarClass"]');
        var carSelect = document.querySelector('select[name="CarName"]');
        if (!classSelect || !carSelect) return;

        function filterCarsByClass(cls) {
            return cars.filter(function (c) { return cls ? (c['class'] === cls) : true; }).map(function (c) { return c.name; });
        }

        function populate(select, items, placeholderText) {
            var current = select.value;
            select.innerHTML = '';
            var ph = document.createElement('option');
            ph.value = '';
            ph.text = placeholderText;
            select.appendChild(ph);
            items.forEach(function (it) {
                var opt = document.createElement('option');
                opt.value = it;
                opt.text = it;
                select.appendChild(opt);
            });
            if (current) select.value = current;
        }

        classSelect.addEventListener('change', function () {
            var cls = classSelect.value;
            var names = filterCarsByClass(cls);
            populate(carSelect, names, '-- select car --');
        });

        // initialize car list based on currently selected class (if any)
        var initialClass = classSelect.value;
        populate(carSelect, filterCarsByClass(initialClass), '-- select car --');
    })();
</script>

<script>
    (function () {
        var form = document.getElementById('fuelCalcForm');
        if (!form) return;

        form.addEventListener('submit', function (e) {
            e.preventDefault();

            // collect form values
            var getVal = function (name) {
                var el = form.querySelector('[name="' + name + '"]');
                return el ? el.value : null;
            };

            var model = {
                TrackName: getVal('TrackName') || '',
                EventDurationMinutes: parseInt(getVal('EventDurationMinutes') || '0', 10),
                FuelPerLap: parseFloat(getVal('FuelPerLap') || '0'),
                TimePerLap: parseFloat(getVal('TimePerLap') || '0'),
                CarName: getVal('CarName') || '',
                CarClass: getVal('CarClass') || '',
                PitBoxTime: parseFloat(getVal('PitBoxTime') || '0'),
                DriveThroughTime: parseFloat(getVal('DriveThroughTime') || '0'),
                FuelTankCapacity: parseFloat(getVal('FuelTankCapacity') || '0')
            };

            // antiforgery token
            var tokenEl = form.querySelector('input[name="__RequestVerificationToken"]');
            var token = tokenEl ? tokenEl.value : '';

            fetch('@Url.Action("Calculate", "FuelCalc")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json; charset=utf-8',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify(model)
            }).then(function (res) {
                if (!res.ok) throw new Error('Request failed');
                return res.json();
            }).then(function (data) {
                // update result fields
                var setVal = function (name, value) {
                    var el = form.querySelector('[name="' + name + '"]');
                    if (el) el.value = value;
                };

                setVal('NumberOfPitStops', data.numberOfPitStops);
                setVal('Laps', data.laps);
                setVal('TotalFuelNeeded', data.totalFuelNeeded);

                // append to recent table (match the table header order)
                try {
                    var tbody = document.querySelector('table.table tbody');
                    if (tbody) {
                        var tr = document.createElement('tr');
                        // columns: Track Name, Car Name, Car Class, Fuel Per Lap, Laptime, Event Duration (Minutes), Number of Pitstops, Number of Laps, Total Fuel Needed, Created At
                        var createdAtText = '';
                        if (data.createdAt) {
                            var dt = new Date(data.createdAt);
                            if (!isNaN(dt.getTime())) createdAtText = dt.toLocaleString();
                        }

                        var cols = [
                            data.trackName,
                            data.carName,
                            data.carClass,
                            data.fuelPerLap,
                            data.timePerLap,
                            data.eventDurationMinutes,
                            data.numberOfPitStops,
                            data.laps,
                            data.totalFuelNeeded,
                            createdAtText
                        ];

                        cols.forEach(function (c) {
                            var td = document.createElement('td');
                            td.textContent = c ?? '';
                            tr.appendChild(td);
                        });
                        tbody.insertBefore(tr, tbody.firstChild);
                    }
                } catch (err) {
                    // ignore DOM errors
                }
            }).catch(function (err) {
                console.error(err);
                // fallback to full-post if AJAX fails
                form.removeEventListener('submit', arguments.callee);
                form.submit();
            });
        });
    })();
</script>

