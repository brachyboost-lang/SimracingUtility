@{
    ViewData["Title"] = "Startseite";
}

<div class="text-center mb-5">
    <h1 class="display-4">SimracingUtility</h1>
    <p class="lead">Zentrale Plattform für Sim-Racing: Spritrechner, Setup-Hub und Renndaten-Integration.</p>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body d-flex flex-column">
                <h5 class="card-title">Fuel Calculator</h5>
                <p class="card-text flex-grow-1">
                    Berechne Tankmenge, Boxenstopps und Runden für zeitbasierte Rennen –
                    inklusive Verlauf deiner Berechnungen.
                </p>
                <a asp-controller="FuelCalc" asp-action="Index" class="btn btn-primary mt-auto">Zum Rechner</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body d-flex flex-column">
                <h5 class="card-title">Setup-Hub</h5>
                <p class="card-text flex-grow-1">
                    Lade Fahrzeug-Setups für iRacing, Le Mans Ultimate und ACC hoch,
                    filtere nach Auto und Strecke und teile sie mit dem Team.
                </p>
                <a asp-controller="Setup" asp-action="Index" class="btn btn-primary mt-auto">Zum Setup-Hub</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body d-flex flex-column">
                <h5 class="card-title">LMU-Agent</h5>
                <p class="card-text flex-grow-1">
                    Lokaler Windows-Dienst, der Renndaten automatisch aus Le Mans Ultimate
                    ausliest und bereitstellt.
                </p>
                <a asp-controller="Download" asp-action="Index" class="btn btn-outline-primary mt-auto">Herunterladen</a>
            </div>
        </div>
    </div>
</div>
