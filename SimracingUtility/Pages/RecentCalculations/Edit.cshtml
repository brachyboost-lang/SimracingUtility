@page "{id:int}"
@model SimracingUtility.Pages.RecentCalculations.EditModel
@{
    ViewData["Title"] = "Edit Calculation";
}

<h2>Edit Calculation</h2>

<form method="post">
    <input type="hidden" asp-for="Calculation.Id" />
    <div class="form-group">
        <label asp-for="Calculation.TrackName"></label>
        <input asp-for="Calculation.TrackName" class="form-control" />
        <span asp-validation-for="Calculation.TrackName" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Calculation.CarName"></label>
        <input asp-for="Calculation.CarName" class="form-control" />
        <span asp-validation-for="Calculation.CarName" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Calculation.EventDurationMinutes"></label>
        <input asp-for="Calculation.EventDurationMinutes" class="form-control" />
        <span asp-validation-for="Calculation.EventDurationMinutes" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
</form>

<a asp-page="Index">Back to list</a>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}