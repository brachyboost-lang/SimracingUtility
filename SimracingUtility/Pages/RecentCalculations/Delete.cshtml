@page "{id:int}"
@model SimracingUtility.Pages.RecentCalculations.DeleteModel
@{
    ViewData["Title"] = "Delete Calculation";
}

<h2>Delete Calculation</h2>

<p>Are you sure you want to delete this calculation?</p>
<dl class="row">
    <dt class="col-sm-3">Track</dt>
    <dd class="col-sm-9">@Model.Calculation?.TrackName</dd>
    <dt class="col-sm-3">Car</dt>
    <dd class="col-sm-9">@Model.Calculation?.CarName</dd>
</dl>

<form method="post">
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-page="Index" class="btn btn-secondary">Cancel</a>
</form>